<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ambassade de Côte d'Ivoire — République de Côte d'Ivoire</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Cormorant+Garamond:wght@300;400;600&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --orange: #F77F00;
    --orange-dark: #D4600A;
    --orange-light: #FFB347;
    --white: #FDFAF5;
    --green: #009A44;
    --green-dark: #006B30;
    --green-light: #4DC87A;
    --gold: #C9973A;
    --gold-light: #E8C06A;
    --dark: #1A0F00;
    --charcoal: #2C1A00;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--white);
    color: var(--dark);
    overflow-x: hidden;
  }

  /* ===== NAVBAR ===== */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 4rem;
    height: 80px;
    background: rgba(26,15,0,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 2px solid var(--gold);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .flag-mini {
    display: flex;
    height: 32px;
    width: 48px;
    border-radius: 3px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.4);
  }
  .flag-mini .f1 { flex:1; background: var(--orange); }
  .flag-mini .f2 { flex:1; background: var(--white); }
  .flag-mini .f3 { flex:1; background: var(--green); }

  .nav-title {
    font-family: 'Playfair Display', serif;
    color: var(--white);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.2;
  }
  .nav-title span {
    display: block;
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--gold-light);
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }
  .nav-links a {
    text-decoration: none;
    color: rgba(255,255,255,0.8);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color 0.3s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0; right: 0;
    height: 1px;
    background: var(--orange);
    transform: scaleX(0);
    transition: transform 0.3s;
  }
  .nav-links a:hover { color: var(--orange-light); }
  .nav-links a:hover::after { transform: scaleX(1); }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 700px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--dark);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 70% 50%, rgba(247,127,0,0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 10% 80%, rgba(0,154,68,0.12) 0%, transparent 50%),
      linear-gradient(135deg, #1A0F00 0%, #2C1A00 50%, #0D2B15 100%);
  }

  /* Geometric pattern overlay */
  .hero-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(201,151,58,0.03) 40px, rgba(201,151,58,0.03) 41px),
      repeating-linear-gradient(-45deg, transparent, transparent 40px, rgba(201,151,58,0.03) 40px, rgba(201,151,58,0.03) 41px);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 4rem;
    max-width: 700px;
    animation: fadeUp 1.2s ease both;
  }

  .hero-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 40px;
    height: 1px;
    background: var(--orange);
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 900;
    color: var(--white);
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--orange-light);
  }

  .hero-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 300;
    color: rgba(253,250,245,0.7);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 480px;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 0.9rem 2rem;
    background: var(--orange);
    color: #fff;
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .btn-primary::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: rgba(255,255,255,0.15);
    transition: left 0.4s;
  }
  .btn-primary:hover { background: var(--orange-dark); }
  .btn-primary:hover::before { left: 100%; }

  .btn-outline {
    padding: 0.9rem 2rem;
    background: transparent;
    color: var(--white);
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: 1px solid rgba(255,255,255,0.3);
    cursor: pointer;
    transition: all 0.3s;
  }
  .btn-outline:hover {
    border-color: var(--green);
    color: var(--green-light);
  }

  /* SVG Elephant decorative */
  .hero-elephant {
    position: absolute;
    right: -2%;
    bottom: 0;
    width: 55%;
    max-width: 700px;
    opacity: 0.12;
    animation: floatElephant 8s ease-in-out infinite;
  }

  .hero-elephant-small {
    position: absolute;
    right: 5%;
    bottom: 10%;
    width: 38%;
    max-width: 500px;
    opacity: 0.6;
    filter: drop-shadow(0 20px 60px rgba(247,127,0,0.3));
    animation: floatElephant 6s ease-in-out infinite reverse;
  }

  /* Tricolor stripe at bottom */
  .hero-stripe {
    position: absolute;
    bottom: 0;
    left: 0; right: 0;
    height: 6px;
    display: flex;
  }
  .hero-stripe span { flex: 1; }
  .hero-stripe span:nth-child(1) { background: var(--orange); }
  .hero-stripe span:nth-child(2) { background: var(--white); }
  .hero-stripe span:nth-child(3) { background: var(--green); }

  /* ===== SERVICES BAND ===== */
  .services-band {
    background: var(--orange);
    padding: 2rem 4rem;
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .service-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: opacity 0.3s;
  }
  .service-item:hover { opacity: 0.7; }
  .service-item svg { width: 24px; height: 24px; opacity: 0.9; }

  /* ===== ABOUT SECTION ===== */
  .about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }

  .about-visual {
    position: relative;
    background: linear-gradient(135deg, var(--green-dark), var(--dark));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    min-height: 500px;
  }

  .about-visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 40% 60%, rgba(247,127,0,0.2), transparent 70%);
  }

  .about-elephant-wrap {
    position: relative;
    z-index: 1;
    width: 80%;
    max-width: 420px;
    filter: drop-shadow(0 10px 40px rgba(247,127,0,0.4));
    animation: floatElephant 7s ease-in-out infinite;
  }

  .about-content {
    padding: 5rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--white);
  }

  .section-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .section-label::before {
    content: '';
    width: 30px; height: 1px;
    background: var(--orange);
    display: block;
  }

  .about-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    color: var(--dark);
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }

  .about-content p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    font-weight: 300;
    line-height: 1.9;
    color: var(--charcoal);
    margin-bottom: 1.25rem;
    opacity: 0.85;
  }

  .about-stats {
    display: flex;
    gap: 2.5rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0,0,0,0.1);
  }

  .stat {
    text-align: left;
  }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--orange);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--charcoal);
    opacity: 0.6;
    margin-top: 0.3rem;
  }

  /* ===== FLAG SECTION ===== */
  .flag-section {
    background: var(--dark);
    padding: 5rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .flag-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(247,127,0,0.1), transparent 50%),
      radial-gradient(ellipse at 80% 50%, rgba(0,154,68,0.1), transparent 50%);
  }

  .flag-display {
    position: relative;
    z-index: 1;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .flag-large {
    display: flex;
    width: 240px;
    height: 160px;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6), 0 0 0 2px rgba(201,151,58,0.3);
    position: relative;
    animation: flagWave 4s ease-in-out infinite;
  }
  .flag-large div { flex: 1; }
  .flag-large .f1 { background: var(--orange); }
  .flag-large .f2 { background: #FFFFFF; }
  .flag-large .f3 { background: var(--green); }

  .flag-section h2 {
    position: relative;
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    color: var(--white);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .flag-section p {
    position: relative;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: rgba(255,255,255,0.6);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.8;
  }

  /* ===== SERVICES SECTION ===== */
  .services {
    padding: 6rem 4rem;
    background: var(--white);
  }

  .services-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .services-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 0.75rem;
  }
  .services-header p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    color: var(--charcoal);
    opacity: 0.7;
    max-width: 500px;
    margin: 0 auto;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: rgba(0,0,0,0.08);
    max-width: 1100px;
    margin: 0 auto;
  }

  .service-card {
    background: var(--white);
    padding: 2.5rem;
    cursor: pointer;
    transition: all 0.4s;
    border-bottom: 3px solid transparent;
    position: relative;
    overflow: hidden;
  }
  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, var(--orange), var(--green));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s;
  }
  .service-card:hover { background: #FFF8F0; }
  .service-card:hover::before { transform: scaleX(1); }

  .service-card-icon {
    width: 52px;
    height: 52px;
    background: linear-gradient(135deg, rgba(247,127,0,0.12), rgba(247,127,0,0.04));
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    transition: all 0.3s;
  }
  .service-card:hover .service-card-icon {
    background: linear-gradient(135deg, rgba(247,127,0,0.25), rgba(247,127,0,0.1));
  }
  .service-card-icon svg { width: 26px; height: 26px; stroke: var(--orange); }

  .service-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 0.6rem;
  }
  .service-card p {
    font-size: 0.82rem;
    line-height: 1.75;
    color: var(--charcoal);
    opacity: 0.7;
    margin-bottom: 1.25rem;
  }
  .service-card-link {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: gap 0.3s;
  }
  .service-card:hover .service-card-link { gap: 0.8rem; }

  /* ===== ELEPHANT PRIDE SECTION ===== */
  .pride-section {
    background: linear-gradient(135deg, var(--green-dark) 0%, var(--dark) 60%);
    padding: 6rem 4rem;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    gap: 4rem;
  }

  .pride-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(247,127,0,0.08), transparent 70%);
  }

  .pride-elephants {
    display: flex;
    position: relative;
    flex-shrink: 0;
    width: 380px;
  }

  .pride-elephant {
    width: 180px;
    filter: drop-shadow(0 10px 30px rgba(0,0,0,0.5));
    animation: floatElephant 5s ease-in-out infinite;
  }
  .pride-elephant:nth-child(2) {
    width: 220px;
    margin-left: -40px;
    margin-top: 30px;
    animation-delay: -2.5s;
  }

  .pride-content {
    flex: 1;
  }
  .pride-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: var(--white);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .pride-content h2 em {
    font-style: italic;
    color: var(--orange-light);
  }
  .pride-content p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.9;
    max-width: 500px;
  }

  /* ===== NEWS SECTION ===== */
  .news {
    padding: 6rem 4rem;
    background: #F5EFE6;
  }

  .news-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3rem;
  }
  .news-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--dark);
  }
  .news-header a {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange);
    text-decoration: none;
  }

  .news-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 1.5px;
    background: rgba(0,0,0,0.06);
  }

  .news-card {
    background: var(--white);
    padding: 2rem;
    transition: background 0.3s;
    cursor: pointer;
  }
  .news-card:hover { background: #FFFBF5; }

  .news-tag {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 0.75rem;
  }
  .news-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--dark);
    line-height: 1.4;
    margin-bottom: 0.75rem;
  }
  .news-card:first-child h3 { font-size: 1.5rem; }
  .news-card p {
    font-size: 0.82rem;
    line-height: 1.7;
    color: var(--charcoal);
    opacity: 0.7;
    margin-bottom: 1rem;
  }
  .news-date {
    font-size: 0.65rem;
    color: var(--charcoal);
    opacity: 0.5;
    letter-spacing: 0.1em;
  }

  /* ===== CONTACT SECTION ===== */
  .contact {
    background: var(--dark);
    padding: 5rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-info h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    color: var(--white);
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .contact-detail {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.75rem;
    align-items: flex-start;
  }
  .contact-detail-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(247,127,0,0.15);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .contact-detail-icon svg { width: 16px; height: 16px; stroke: var(--orange); }
  .contact-detail-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 0.3rem;
  }
  .contact-detail-text {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
  }

  .contact-hours {
    background: rgba(247,127,0,0.08);
    border: 1px solid rgba(247,127,0,0.2);
    border-radius: 4px;
    padding: 1.5rem;
    margin-top: 2rem;
  }
  .contact-hours-title {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-light);
    margin-bottom: 1rem;
  }
  .hours-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.65);
    padding: 0.35rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .hours-row:last-child { border-bottom: none; }
  .hours-row strong { color: rgba(255,255,255,0.9); }

  /* Contact form */
  .contact-form h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--white);
    margin-bottom: 1.5rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }
  .form-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.5rem;
  }
  .form-control {
    width: 100%;
    padding: 0.85rem 1rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 2px;
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    transition: border-color 0.3s;
    outline: none;
  }
  .form-control:focus { border-color: var(--orange); }
  .form-control::placeholder { color: rgba(255,255,255,0.25); }
  textarea.form-control { resize: none; height: 110px; }

  /* ===== FOOTER ===== */
  footer {
    background: #0D0800;
    padding: 2rem 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .footer-flag {
    display: flex;
    height: 20px;
    width: 30px;
    border-radius: 2px;
    overflow: hidden;
